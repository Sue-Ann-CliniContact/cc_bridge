# ─── Django ────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
APP_BASE_URL=http://localhost:8000

# ─── Database (Postgres via dj-database-url) ───────────
# Local dev: postgresql://user:pass@localhost:5432/cc_bridge
# Render:    injected automatically when you link a Postgres service
DB_INTERNAL=postgresql://postgres:postgres@localhost:5432/cc_bridge

# ─── Monday.com OAuth + Workspace ──────────────────────
MONDAY_CLIENT_ID=
MONDAY_CLIENT_SECRET=
MONDAY_REDIRECT_URI=http://localhost:8000/oauth/callback/
# Dedicated Bridge workspace — create in Monday and paste ID here
MONDAY_WORKSPACE_ID=

# ─── Instantly ─────────────────────────────────────────
INSTANTLY_API_KEY=

# ─── Anthropic (Claude — Lini + email drafting) ────────
ANTHROPIC_API_KEY=

# ─── Apollo (Phase 2 — leave blank until key in hand) ──
APOLLO_API_KEY=
APOLLO_MONTHLY_BUDGET_CREDITS=1000
